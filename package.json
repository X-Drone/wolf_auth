{
  "name": "wolf_auth",
  "version": "1.1.0",
  "main": "index.js",
  "scripts": {
    "install-client": "cd client && npm install",
    "install-server": "cd server/backend && pip install -r requirements.txt",
    "install-all": "npm run install-client && npm run install-server",

    "frontend": "cd client && npm start",
    "backend": "cd server/backend/src && uvicorn main:app --reload --host 0.0.0.0 --port 8000",

    "dev": "concurrently \"npm run frontend\" \"npm run backend\"",

    "build": "cd client && npm run build",
    "start": "npm run backend"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/X-Drone/wolf_auth.git"
  },
  "author": "X-Drone",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/X-Drone/wolf_auth/issues"
  },
  "homepage": "https://github.com/X-Drone/wolf_auth#readme",
  "description": "",
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
